cat > .gitignore << 'EOF'
# VS Code
.vscode/
*.code-workspace

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
.venv/
pip-log.txt
pip-delete-this-directory.txt
.pytest_cache/

# C#
bin/
obj/
*.user
*.suo
*.userprefs
*.dll
*.exe
*.pdb
*.cache
Debug/
Release/

# macOS
.DS_Store
*.swp
*.lock
*.log

# Excel временные файлы
~$*.xlsx
*.xlsx~
EOF